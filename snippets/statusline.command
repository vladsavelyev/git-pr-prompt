input=$(cat); model=$(echo "$input" | jq -r '.model.display_name'); cwd=$(echo "$input" | jq -r '.workspace.current_dir'); used_tok=$(echo "$input" | jq -r '.context_window.total_input_tokens // empty'); cost=$(echo "$input" | jq -r '.cost.total_cost_usd // empty'); transcript=$(echo "$input" | jq -r '.transcript_path // empty'); case "$model" in *Haiku*) max_tok=200000;; *) max_tok=1000000;; esac; short_dir="${cwd/#$HOME/~}"; git_branch=$(git -C "$cwd" -c core.fileMode=false rev-parse --abbrev-ref HEAD 2>/dev/null); out=$(printf '\033[38;5;45m')"${short_dir}"$(printf '\033[0m'); if [ -n "$git_branch" ]; then out="$out $(printf '\033[38;5;76m')  $git_branch$(printf '\033[0m')"; fi; prctx=$(git-pr-context "$cwd" 2>/dev/null); pr_parent=$(printf '%s' "$prctx" | cut -f1); pr_num=$(printf '%s' "$prctx" | cut -f2); pr_url=$(printf '%s' "$prctx" | cut -f3); if [ -n "$pr_parent" ]; then out="$out $(printf '\033[38;5;244m')→ $pr_parent$(printf '\033[0m')"; fi; if [ -n "$pr_num" ]; then if [ -n "$pr_url" ]; then pr_link=$(printf '\033]8;;%s\033\\#%s\033]8;;\033\\' "$pr_url" "$pr_num"); else pr_link="#$pr_num"; fi; out="$out $(printf '\033[38;5;39m')$pr_link$(printf '\033[0m')"; fi; out="$out $(printf '\033[38;5;141m')$model$(printf '\033[0m')"; if [ -n "$used_tok" ]; then used_int=$((used_tok * 100 / max_tok)); if [ "$used_int" -gt 100 ]; then used_int=100; fi; bar_width=20; filled=$((used_int * bar_width / 100)); empty=$((bar_width - filled)); if [ "$used_int" -lt 50 ]; then bar_color='\033[38;5;76m'; elif [ "$used_int" -lt 80 ]; then bar_color='\033[38;5;178m'; else bar_color='\033[38;5;196m'; fi; bar="${bar_color}["; i=0; while [ $i -lt $filled ]; do bar="${bar}="; i=$((i+1)); done; i=0; while [ $i -lt $empty ]; do bar="${bar} "; i=$((i+1)); done; tok_label=$(awk -v u="$used_tok" -v m="$max_tok" 'BEGIN{printf "%.1fk/%dk", u/1000, m/1000}'); bar="${bar}]$(printf '\033[0m') ${tok_label}"; out="$out $bar"; fi; if [ -n "$cost" ]; then cost_label=$(awk -v c="$cost" 'BEGIN{printf "$%.2f", c}'); out="$out $(printf '\033[38;5;222m')${cost_label}$(printf '\033[0m')"; fi; if [ -n "$transcript" ] && command -v claude-spend >/dev/null 2>&1; then allin=$(claude-spend --session "$transcript" 2>/dev/null); if [ -n "$allin" ]; then out="$out $(printf '\033[38;5;208m')Σ${allin}$(printf '\033[0m')"; fi; fi; echo "$out"
