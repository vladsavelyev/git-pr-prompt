  <header>
    <h1>Claude spend</h1>
    <div>
      <span class="gen">generated {generated}</span>
      <button class="toggle" onclick="var r=document.documentElement;r.dataset.theme=r.dataset.theme==='dark'?'light':'dark'">theme</button>
    </div>
  </header>

  <div class="kpis">{tiles}</div>

  <div class="card">
    <h2>Cost by period</h2>
    {bar_rows}
  </div>

  <div class="card">
    <h2>Daily cost — last 30 days</h2>
    <svg viewBox="0 0 {W} {H}" role="img" aria-label="Daily cost, last 30 days">
      <path d="{area_path}" fill="var(--blue-soft)" opacity="0.55"/>
      <path d="{line_path}" fill="none" stroke="var(--blue)" stroke-width="2"
            stroke-linejoin="round" stroke-linecap="round"/>
      {dots}
    </svg>
    <div class="trend-meta">
      <span>{first_lbl}</span>
      <span>peak {peak_lbl}: {peak_val}</span>
      <span>{last_lbl}</span>
    </div>
  </div>

  <div class="card">
    <h2>By model — this month</h2>
    <table>
      <thead>
        <tr>
          <th>model</th><th>cost</th><th>in</th><th>out</th>
          <th>cache rd</th><th>cache wr</th><th>hit%</th><th>msgs</th><th>convos</th>
        </tr>
      </thead>
      <tbody>{trows}</tbody>
    </table>
    {note}
  </div>

  <p class="foot">Cost is computed from token counts &times; per-model pricing (not
  recorded in transcripts). Every message is deduplicated by id, since resumed and
  forked sessions copy messages across transcript files.</p>
</div>
</body>
</html>
"""


def open_in_browser(path):
    url = "file://" + os.path.abspath(path)
    # On macOS `open` is the most reliable; fall back to the stdlib elsewhere.
    if sys.platform == "darwin":
        subprocess.run(["open", url], check=False)
    else:
        webbrowser.open(url)


def main():
    ap = argparse.ArgumentParser(
        description="Report Claude Code token/money spending over a period."
    )
    ap.add_argument(
        "period",
        nargs="?",
        default=DEFAULT_PERIOD,
        help=f"one of: {', '.join(PERIODS)} (default: {DEFAULT_PERIOD})",
    )
    ap.add_argument(
        "--all",
        action="store_true",
        help="show every period as a summary row (totals only)",
    )
    ap.add_argument("--json", action="store_true", help="emit JSON instead of a table")
    ap.add_argument(
        "--open",
        action="store_true",
        help="build an HTML dashboard and open it in your browser",
    )
    args = ap.parse_args()

    # `claude-spend open` is a friendly alias for `claude-spend --open`.
    if args.period == "open":
        args.open = True
        args.period = DEFAULT_PERIOD

    period = ALIASES.get(args.period, args.period)
    if not args.all and period not in PERIODS:
        ap.error(f"unknown period {args.period!r}; choose from: {', '.join(PERIODS)}")

    now = datetime.now()
    stats, daily, unpriced = collect(now)

    if args.open:
        doc = render_html(stats, daily, unpriced, now)
        path = os.path.join(tempfile.gettempdir(), "claude-spend.html")
        with open(path, "w") as fh:
            fh.write(doc)
        print(f"wrote {path}")
        open_in_browser(path)
        return

    if args.json:
        if args.all:
            payload = {
                "periods": {p: to_jsonable(stats[p]) for p in PERIODS},
                "unpriced_models": sorted(unpriced),
            }
        else:
            payload = {
                "period": period,
                "models": to_jsonable(stats[period]),
                "unpriced_models": sorted(unpriced),
            }
        print(json.dumps(payload, indent=2))
        return

    if args.all:
        print_all(stats, unpriced)
    else:
        print_period(period, stats[period], unpriced)


if __name__ == "__main__":
    main()
