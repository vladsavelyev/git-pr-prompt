def open_in_browser(path):
    url = "file://" + os.path.abspath(path)
    # On macOS `open` is the most reliable; fall back to the stdlib elsewhere.
    if sys.platform == "darwin":
        subprocess.run(["open", url], check=False)
    else:
        webbrowser.open(url)


def main():
    ap = argparse.ArgumentParser(
        description="Report Claude Code token/money spending over a period."
    )
    ap.add_argument(
        "period",
        nargs="?",
        default=DEFAULT_PERIOD,
        help=f"one of: {', '.join(PERIODS)} (default: {DEFAULT_PERIOD})",
    )
    ap.add_argument(
        "--all",
        action="store_true",
        help="show every period as a summary row (totals only)",
    )
    ap.add_argument("--json", action="store_true", help="emit JSON instead of a table")
    ap.add_argument(
        "--open",
        action="store_true",
        help="build an HTML dashboard and open it in your browser",
    )
    ap.add_argument(
        "--session",
        metavar="TRANSCRIPT",
        help="report just one session's all-in cost (main + subagents) from its "
        "transcript path (statusline gives .transcript_path); prints a bare "
        "'$X.XX' unless --json is given",
    )
    ap.add_argument(
        "--subagents-only",
        action="store_true",
        help="with --session: sum only the subagent transcripts (excludes the "
        "main transcript). Pair with --add to combine with the statusline's "
        "live main-agent cost without the one-turn disk-flush lag.",
    )
    ap.add_argument(
        "--add",
        type=float,
        metavar="USD",
        default=0.0,
        help="with --session: add this many USD to the computed cost before "
        "printing (statusline passes Claude's live .cost.total_cost_usd here).",
    )
    args = ap.parse_args()

    # Single-session mode: the all-in figure the statusline's built-in
    # cost.total_cost_usd misses (subagent turns live in separate transcripts).
    if args.session:
        s = session_stats(args.session, subagents_only=args.subagents_only)
        total = s["cost"] + args.add
        if args.json:
            payload = {"transcript": args.session, **to_jsonable({"_": s})["_"]}
            if args.add:
                payload["added_usd"] = round(args.add, 4)
                payload["total_usd"] = round(total, 4)
            print(json.dumps(payload))
        else:
            print(fmt_cost(total))
        return

    # `claude-spend open` is a friendly alias for `claude-spend --open`.
    if args.period == "open":
        args.open = True
        args.period = DEFAULT_PERIOD

    period = ALIASES.get(args.period, args.period)
    if not args.all and period not in PERIODS:
        ap.error(f"unknown period {args.period!r}; choose from: {', '.join(PERIODS)}")

    now = datetime.now()
    stats, daily, unpriced = collect(now)

    if args.open:
        doc = render_html(stats, daily, unpriced, now)
        path = os.path.join(tempfile.gettempdir(), "claude-spend.html")
        with open(path, "w") as fh:
            fh.write(doc)
        print(f"wrote {path}")
        open_in_browser(path)
        return

    if args.json:
        if args.all:
            payload = {
                "periods": {p: to_jsonable(stats[p]) for p in PERIODS},
                "unpriced_models": sorted(unpriced),
            }
        else:
            payload = {
                "period": period,
                "models": to_jsonable(stats[period]),
                "unpriced_models": sorted(unpriced),
            }
        print(json.dumps(payload, indent=2))
        return

    if args.all:
        print_all(stats, unpriced)
    else:
        print_period(period, stats[period], unpriced)


if __name__ == "__main__":
    main()
