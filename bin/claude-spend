#!/usr/bin/env python3
"""claude-spend — report Claude Code token/money spending over a time period.

Reads the local Claude Code transcripts under ~/.claude/projects/**/*.jsonl,
derives cost from token usage x per-model pricing (cost is NOT stored in the
transcripts), and aggregates by period, split by model.

  claude-spend                 # this month (default)
  claude-spend today
  claude-spend last-day        # yesterday
  claude-spend this-week last-week this-month last-month lifetime
  claude-spend --all           # one row per period, totals only
  claude-spend --json this-month
  claude-spend open            # build an HTML dashboard and open it

Metrics: token spending (input / output / cache read / cache write), money
spending (USD), cache hit rate, convos (distinct sessions), messages (assistant
turns).

Why dedup: sessions get forked/resumed and their messages are copied into new
transcript files, so the same API response (message.id) appears many times.
Every number here is deduplicated by message id, or it would inflate ~2x.
"""

import argparse
import glob
import html
import json
import os
import subprocess
import sys
import tempfile
import webbrowser
from collections import defaultdict
from datetime import datetime, timedelta

PROJECTS_DIR = os.path.expanduser("~/.claude/projects")

# Per-1M-token pricing (input, output) in USD. Sourced from the Claude model
# catalog. Models absent here are billed as $0 and flagged in the output.
PRICING = {
    "claude-fable-5": (10.0, 50.0),
    "claude-mythos-5": (10.0, 50.0),
    "claude-opus-4-8": (5.0, 25.0),
    "claude-opus-4-7": (5.0, 25.0),
    "claude-opus-4-6": (5.0, 25.0),
    "claude-opus-4-5": (5.0, 25.0),
    "claude-opus-4-1": (15.0, 75.0),
    "claude-opus-4-0": (15.0, 75.0),
    "claude-sonnet-5": (3.0, 15.0),
    "claude-sonnet-4-6": (3.0, 15.0),
    "claude-sonnet-4-5": (3.0, 15.0),
    "claude-sonnet-4-0": (3.0, 15.0),
    "claude-haiku-4-5": (1.0, 5.0),
    "claude-3-5-haiku": (0.80, 4.0),
}

# Cache token cost as a multiple of the input price.
CACHE_READ_MULT = 0.10
CACHE_WRITE_5M_MULT = 1.25
CACHE_WRITE_1H_MULT = 2.0

# Periods in nesting order (each is a superset of the ones before it, roughly),
# rendered top-to-bottom in --all.
PERIODS = [
    "today",
    "last-day",
    "this-week",
    "last-week",
    "this-month",
    "last-month",
    "lifetime",
]
DEFAULT_PERIOD = "this-month"

# Aliases so common phrasings just work.
ALIASES = {
    "yesterday": "last-day",
    "week": "this-week",
    "month": "this-month",
    "all-time": "lifetime",
    "all": "lifetime",
    "total": "lifetime",
}


def price_for(model):
    """Return (input, output) per-1M price, or None if the model is unpriced."""
    if model in PRICING:
        return PRICING[model]
    # Strip a trailing -YYYYMMDD date snapshot (e.g. claude-haiku-4-5-20251001).
    parts = model.rsplit("-", 1)
    if len(parts) == 2 and parts[1].isdigit() and len(parts[1]) == 8:
        base = parts[0]
        if base in PRICING:
            return PRICING[base]
    # Longest known prefix.
    for key in sorted(PRICING, key=len, reverse=True):
        if model.startswith(key):
            return PRICING[key]
    return None


def record_cost(model, inp, cw5, cw1, cr, out):
    price = price_for(model)
    if price is None:
        return 0.0
    pin, pout = price
    return (
        inp * pin
        + cw5 * pin * CACHE_WRITE_5M_MULT
        + cw1 * pin * CACHE_WRITE_1H_MULT
        + cr * pin * CACHE_READ_MULT
        + out * pout
    ) / 1_000_000.0


def period_bounds(now):
    """Return a dict period -> predicate(date) using local dates."""
    today = now.date()
    yesterday = today - timedelta(days=1)
    this_monday = today - timedelta(days=today.weekday())
    next_monday = this_monday + timedelta(days=7)
    last_monday = this_monday - timedelta(days=7)

    # First day of last month.
    if today.month == 1:
        lm_year, lm_month = today.year - 1, 12
    else:
        lm_year, lm_month = today.year, today.month - 1

    return {
        "today": lambda d: d == today,
        "last-day": lambda d: d == yesterday,
        "this-week": lambda d: this_monday <= d < next_monday,
        "last-week": lambda d: last_monday <= d < this_monday,
        "this-month": lambda d: d.year == today.year and d.month == today.month,
        "last-month": lambda d: d.year == lm_year and d.month == lm_month,
        "lifetime": lambda d: True,
    }


def new_stats():
    return {
        "inp": 0,
        "out": 0,
        "cr": 0,      # cache read
        "cw5": 0,     # cache write 5m
        "cw1": 0,     # cache write 1h
        "cost": 0.0,
        "msgs": 0,
        "sessions": set(),
    }


def collect(now):
    """Parse all transcripts once. Return (stats, unpriced_models set).

    stats[period][model] -> aggregated dict.
    """
    files = glob.glob(os.path.join(PROJECTS_DIR, "**", "*.jsonl"), recursive=True)
    if not files:
        sys.exit(f"No transcripts found under {PROJECTS_DIR}")

    bounds = period_bounds(now)
    stats = {p: defaultdict(new_stats) for p in PERIODS}
    daily = defaultdict(float)  # date iso -> cost, for the trend chart
    seen = set()
    unpriced = set()

    for path in files:
        with open(path, errors="replace") as fh:
            for line in fh:
                # Fast reject: only assistant messages carry a usage block.
                if '"usage"' not in line:
                    continue
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if obj.get("type") != "assistant":
                    continue
                msg = obj.get("message")
                if not isinstance(msg, dict):
                    continue
                usage = msg.get("usage")
                if not usage:
                    continue

                mid = msg.get("id") or obj.get("uuid")
                if mid in seen:
                    continue
                seen.add(mid)

                ts = obj.get("timestamp")
                if not ts:
                    continue
                try:
                    dt_local = datetime.fromisoformat(
                        ts.replace("Z", "+00:00")
                    ).astimezone()
                except ValueError:
                    continue
                d = dt_local.date()

                model = msg.get("model", "unknown")
                inp = usage.get("input_tokens", 0) or 0
                out = usage.get("output_tokens", 0) or 0
                cr = usage.get("cache_read_input_tokens", 0) or 0
                cc = usage.get("cache_creation") or {}
                cw1 = cc.get("ephemeral_1h_input_tokens", 0) or 0
                cw5 = cc.get("ephemeral_5m_input_tokens", 0) or 0
                if not cc:
                    # Older/rolled-up shape: attribute all creation to 5m.
                    cw5 = usage.get("cache_creation_input_tokens", 0) or 0

                cost = record_cost(model, inp, cw5, cw1, cr, out)
                if price_for(model) is None and model != "<synthetic>":
                    unpriced.add(model)

                session = obj.get("sessionId") or obj.get("session_id") or path

                daily[d.isoformat()] += cost

                for p in PERIODS:
                    if bounds[p](d):
                        s = stats[p][model]
                        s["inp"] += inp
                        s["out"] += out
                        s["cr"] += cr
                        s["cw5"] += cw5
                        s["cw1"] += cw1
                        s["cost"] += cost
                        s["msgs"] += 1
                        s["sessions"].add(session)

    return stats, daily, unpriced


# --- formatting -------------------------------------------------------------

def _tty():
    return sys.stdout.isatty()


def c(code, text):
    if not _tty():
        return text
    return f"\033[{code}m{text}\033[0m"


def fmt_tokens(n):
    if n >= 1_000_000_000:
        return f"{n / 1e9:.2f}B"
    if n >= 1_000_000:
        return f"{n / 1e6:.2f}M"
    if n >= 1_000:
        return f"{n / 1e3:.1f}k"
    return str(n)


def fmt_cost(x):
    return f"${x:,.2f}"


def cache_hit_rate(s):
    served = s["cr"]
    total_in = s["inp"] + s["cw5"] + s["cw1"] + s["cr"]
    if total_in == 0:
        return 0.0
    return 100.0 * served / total_in


def merge(models):
    """Merge a dict of per-model stats into one total stats dict."""
    t = new_stats()
    for s in models.values():
        for k in ("inp", "out", "cr", "cw5", "cw1", "cost", "msgs"):
            t[k] += s[k]
        t["sessions"] |= s["sessions"]
    return t


def print_period(period, models, unpriced):
    label = c("1;36", f"Claude spend — {period}")
    print(label)
    if not models:
        print("  (no activity)")
        return

    # Column layout.
    header = (
        f"  {'model':<22}{'cost':>10}{'in':>10}{'out':>10}"
        f"{'cache rd':>11}{'cache wr':>11}{'hit%':>7}{'msgs':>8}{'convos':>8}"
    )
    print(c("2", header))

    total = merge(models)
    # Sort models by cost desc.
    for model in sorted(models, key=lambda m: models[m]["cost"], reverse=True):
        s = models[model]
        cw = s["cw5"] + s["cw1"]
        name = model if len(model) <= 22 else model[:19] + "..."
        row = (
            f"  {name:<22}{fmt_cost(s['cost']):>10}{fmt_tokens(s['inp']):>10}"
            f"{fmt_tokens(s['out']):>10}{fmt_tokens(s['cr']):>11}{fmt_tokens(cw):>11}"
            f"{cache_hit_rate(s):>6.0f}%{s['msgs']:>8}{len(s['sessions']):>8}"
        )
        print(row)

    tcw = total["cw5"] + total["cw1"]
    trow = (
        f"  {'TOTAL':<22}{fmt_cost(total['cost']):>10}{fmt_tokens(total['inp']):>10}"
        f"{fmt_tokens(total['out']):>10}{fmt_tokens(total['cr']):>11}{fmt_tokens(tcw):>11}"
        f"{cache_hit_rate(total):>6.0f}%{total['msgs']:>8}{len(total['sessions']):>8}"
    )
    print(c("1", trow))

    if unpriced:
        print(
            c("33", f"  note: unpriced models billed as $0: {', '.join(sorted(unpriced))}")
        )


def print_all(stats, unpriced):
    print(c("1;36", "Claude spend — all periods"))
    header = (
        f"  {'period':<12}{'cost':>10}{'tokens':>11}{'cache rd':>11}"
        f"{'hit%':>7}{'msgs':>8}{'convos':>8}"
    )
    print(c("2", header))
    for p in PERIODS:
        t = merge(stats[p])
        total_tok = t["inp"] + t["out"] + t["cr"] + t["cw5"] + t["cw1"]
        row = (
            f"  {p:<12}{fmt_cost(t['cost']):>10}{fmt_tokens(total_tok):>11}"
            f"{fmt_tokens(t['cr']):>11}{cache_hit_rate(t):>6.0f}%"
            f"{t['msgs']:>8}{len(t['sessions']):>8}"
        )
        print(row)
    if unpriced:
        print(
            c("33", f"  note: unpriced models billed as $0: {', '.join(sorted(unpriced))}")
        )


def to_jsonable(models):
    out = {}
    for model, s in models.items():
        out[model] = {
            "cost_usd": round(s["cost"], 4),
            "input_tokens": s["inp"],
            "output_tokens": s["out"],
            "cache_read_tokens": s["cr"],
            "cache_write_5m_tokens": s["cw5"],
            "cache_write_1h_tokens": s["cw1"],
            "cache_hit_rate_pct": round(cache_hit_rate(s), 2),
            "messages": s["msgs"],
            "convos": len(s["sessions"]),
        }
    return out


# --- HTML dashboard ---------------------------------------------------------
# Palette + method from the dataviz reference. Cost magnitude is one job (a
# single measure, low->high), so it uses the sequential blue hue, not
# categorical colors. Validated: node scripts/validate_palette.js with the
# blue sequential ramp — a single-hue sequential ramp is safe by construction.

def render_html(stats, daily, unpriced, now):
    esc = html.escape

    def money(x):
        return f"${x:,.2f}"

    def toks(n):
        if n >= 1e9:
            return f"{n / 1e9:.2f}B"
        if n >= 1e6:
            return f"{n / 1e6:.2f}M"
        if n >= 1e3:
            return f"{n / 1e3:.1f}k"
        return str(int(n))

    # KPI tiles: this-month headline + today + this-week + lifetime.
    tm = merge(stats["this-month"])
    td = merge(stats["today"])
    tw = merge(stats["this-week"])
    lt = merge(stats["lifetime"])

    def tile(label, s, hero=False):
        cls = "tile hero" if hero else "tile"
        return f"""
      <div class="{cls}">
        <div class="tile-label">{esc(label)}</div>
        <div class="tile-value">{money(s['cost'])}</div>
        <div class="tile-sub">{toks(s['inp'] + s['out'] + s['cr'] + s['cw5'] + s['cw1'])} tokens · {cache_hit_rate(s):.0f}% cache · {len(s['sessions'])} convos</div>
      </div>"""

    tiles = "".join([
        tile("This month", tm, hero=True),
        tile("Today", td),
        tile("This week", tw),
        tile("Lifetime", lt),
    ])

    # Bar chart: cost by period (sequential blue, single measure).
    bar_periods = ["today", "last-day", "this-week", "last-week",
                   "this-month", "last-month"]
    bar_labels = {"today": "Today", "last-day": "Yesterday",
                  "this-week": "This week", "last-week": "Last week",
                  "this-month": "This month", "last-month": "Last month"}
    bar_vals = [(bar_labels[p], merge(stats[p])["cost"]) for p in bar_periods]
    bmax = max((v for _, v in bar_vals), default=0) or 1
    bar_rows = ""
    for lbl, val in bar_vals:
        pct = 100.0 * val / bmax
        bar_rows += f"""
        <div class="bar-row">
          <div class="bar-name">{esc(lbl)}</div>
          <div class="bar-track"><div class="bar-fill" style="width:{pct:.1f}%"></div></div>
          <div class="bar-val">{money(val)}</div>
        </div>"""

    # Area trend: daily cost, last 30 days.
    days = []
    today = now.date()
    for i in range(29, -1, -1):
        d = today - timedelta(days=i)
        days.append((d, daily.get(d.isoformat(), 0.0)))
    dmax = max((v for _, v in days), default=0) or 1
    W, H, PAD = 720, 200, 24
    n = len(days)
    step = (W - 2 * PAD) / (n - 1) if n > 1 else 0
    pts = []
    for i, (_, v) in enumerate(days):
        x = PAD + i * step
        y = H - PAD - (H - 2 * PAD) * (v / dmax)
        pts.append((x, y))
    line_path = "M" + " L".join(f"{x:.1f},{y:.1f}" for x, y in pts)
    area_path = (
        f"M{pts[0][0]:.1f},{H - PAD:.1f} L"
        + " L".join(f"{x:.1f},{y:.1f}" for x, y in pts)
        + f" L{pts[-1][0]:.1f},{H - PAD:.1f} Z"
    )
    dots = ""
    for (d, v), (x, y) in zip(days, pts):
        dots += (
            f'<circle cx="{x:.1f}" cy="{y:.1f}" r="8" fill="transparent">'
            f'<title>{d.isoformat()}: {money(v)}</title></circle>'
        )
    first_lbl = days[0][0].strftime("%b %-d")
    last_lbl = days[-1][0].strftime("%b %-d")
    peak = max(days, key=lambda dv: dv[1])

    # Model table for this month, cost desc.
    models = stats["this-month"]
    trows = ""
    for m in sorted(models, key=lambda k: models[k]["cost"], reverse=True):
        s = models[m]
        cw = s["cw5"] + s["cw1"]
        trows += f"""
        <tr>
          <td class="model">{esc(m)}</td>
          <td class="num">{money(s['cost'])}</td>
          <td class="num">{toks(s['inp'])}</td>
          <td class="num">{toks(s['out'])}</td>
          <td class="num">{toks(s['cr'])}</td>
          <td class="num">{toks(cw)}</td>
          <td class="num">{cache_hit_rate(s):.0f}%</td>
          <td class="num">{s['msgs']}</td>
          <td class="num">{len(s['sessions'])}</td>
        </tr>"""
    total_cw = tm["cw5"] + tm["cw1"]
    trows += f"""
        <tr class="total-row">
          <td class="model">TOTAL</td>
          <td class="num">{money(tm['cost'])}</td>
          <td class="num">{toks(tm['inp'])}</td>
          <td class="num">{toks(tm['out'])}</td>
          <td class="num">{toks(tm['cr'])}</td>
          <td class="num">{toks(total_cw)}</td>
          <td class="num">{cache_hit_rate(tm):.0f}%</td>
          <td class="num">{tm['msgs']}</td>
          <td class="num">{len(tm['sessions'])}</td>
        </tr>"""

    note = ""
    if unpriced:
        note = (
            '<p class="note">Unpriced models billed as $0: '
            + esc(", ".join(sorted(unpriced)))
            + "</p>"
        )

    generated = now.strftime("%Y-%m-%d %H:%M")

    return _HTML_TEMPLATE.format(
        tiles=tiles,
        bar_rows=bar_rows,
        area_path=area_path,
        line_path=line_path,
        dots=dots,
        first_lbl=esc(first_lbl),
        last_lbl=esc(last_lbl),
        peak_lbl=esc(peak[0].strftime("%b %-d")),
        peak_val=money(peak[1]),
        trows=trows,
        note=note,
        generated=esc(generated),
        W=W,
        H=H,
    )


_HTML_TEMPLATE = """<!DOCTYPE html>
<html lang="en" data-theme="">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Claude spend</title>
<style>
  :root {{
    color-scheme: light;
    --page: #f9f9f7; --surface: #fcfcfb;
    --ink: #0b0b0b; --ink-2: #52514e; --muted: #898781;
    --grid: #e1e0d9; --axis: #c3c2b7;
    --blue: #2a78d6; --blue-soft: #cde2fb;
    --border: rgba(11,11,11,0.10);
  }}
  @media (prefers-color-scheme: dark) {{
