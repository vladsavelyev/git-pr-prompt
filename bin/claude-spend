    border-radius: 8px; padding: 4px 10px; font: inherit; font-size: 13px; cursor: pointer; }}
  .kpis {{ display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 12px; margin-bottom: 28px; }}
